#!/bin/bash
set -e

# Detect the OS distribution
if [ -f /etc/os-release ]; then
  # Load the ID from /etc/os-release
  OS=$(grep ^ID= /etc/os-release | cut -d= -f2 | tr -d '"')
else
  echo "Error: /etc/os-release not found. Unable to identify Linux variant."
  exit 1
fi

case "$OS" in
  debian|ubuntu)
    echo "Detected $OS. Running debian-update..."
    ./debian-update
    ;;
  amzn)
    echo "Detected Amazon Linux. Running aws-update..."
    ./aws-update
    ;;
  *)
    echo "Unsupported OS variant: $OS"
    ;;
esac

source gemini-update
